{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Reel Reader Dev",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^.*vite.*starting dev server.*",
					"endsPattern": "^.*ready in.*ms.*"
				}
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Reel Reader Build",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"group": {
				"kind": "build"
			},
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "Type Check",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"type-check"
			],
			"group": {
				"kind": "test"
			},
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "Type Check",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"type-check"
			],
			"group": "build"
		}
	]
}