# Copy to .env.local and fill with your own keys before running

# OMDb API Key (http://www.omdbapi.com/apikey.aspx)
VITE_OMDB_API_KEY=

# TMDB API Key (https://www.themoviedb.org/settings/api)
VITE_TMDB_API_KEY=

# Last.fm API Key (https://www.last.fm/api/account/create)
VITE_LASTFM_API_KEY=

# YouTube Data API Key (https://console.developers.google.com/apis/credentials)
VITE_YOUTUBE_API_KEY=

# Optional: Spotify (Web API with Authorization Code + PKCE)
# Redirect URI must match what you register in the Spotify dashboard
VITE_SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/auth/spotify/callback

# Optional: Adult/JAV/Doujin sources
VITE_FANZA_API_ID=
VITE_DLSITE_SITE_ID=
VITE_R18_API_BASE=https://r18.dev
VITE_CORS_PROXY=
VITE_NHENTAI_BASE=https://nhentai.net
